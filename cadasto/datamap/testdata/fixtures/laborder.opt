        <archetype_id>
          <value>openEHR-EHR-INSTRUCTION.request-lab_test.v1</value>
        </archetype_id>
        <term_definitions code="at0.145">
          <items id="description">Gestructureerd detail die het afnamemonster omschrijven.</items>
          <items id="text">Details van het afnamemonster</items>
        </term_definitions>
        <term_definitions code="at0000">
          <items id="description">*Generic request for a range of different healthcare services e.g referral, lab request, equipment request.(en)</items>
          <items id="text">*Healthcare service request(en)</items>
        </term_definitions>
        <term_definitions code="at0000.1">
          <items id="description">Generieke aanvraag voor een laboratorium onderzoek.</items>
          <items id="text">Aanvraag laboratorium onderzoek</items>
        </term_definitions>
        <term_definitions code="at0001">
          <items id="description">Huidige activiteit.</items>
          <items id="text">Aanvraag</items>
        </term_definitions>
        <term_definitions code="at0008">
          <items id="description">@ internal @</items>
          <items id="text">Tree</items>
        </term_definitions>
        <term_definitions code="at0009">
          <items id="description">@ internal @</items>
          <items id="text">Tree</items>
        </term_definitions>
        <term_definitions code="at0010">
          <items id="description">De lokale ID die aan de order is toegewezen door de zorgverlener of organisatie die de dienst aanvraagt. Ook wel genoemd Placer Order Identifier.</items>
          <items id="text">Aanvrager ID</items>
        </term_definitions>
        <term_definitions code="at0011">
          <items id="description">De ID toegekend aan de order door de zorgverlener of zorg-organisatie die de aanvraag voor de dienst ontvangen. Ook wel genoemd Filler Order Identifier.</items>
          <items id="text">Ontvanger ID</items>
        </term_definitions>
        <term_definitions code="at0040">
          <items id="description">*The date and time that the service should be performed or completed.(en)</items>
          <items id="text">*Date &amp;/or time service required(en)</items>
        </term_definitions>
        <term_definitions code="at0040.1">
          <items id="description">De voorkeursdatum en -tijd waarop de dienst uitgevoerd of afgerond zou moeten zijn.</items>
          <items id="text">Voorkeursdatum en -tijd voor het onderzoek.</items>
        </term_definitions>
        <term_definitions code="at0062">
          <items id="description">Een korte beschrijving van de reden voor aanvraag. Dit is vaak gecodeerd op basis van externe terminologie.</items>
          <items id="text">Reden voor aanvraag</items>
        </term_definitions>
        <term_definitions code="at0064">
          <items id="description">Een verhalende beschrijving die de reden van de aanvraag uitlegt, toelicht.</items>
          <items id="text">Beschrijving van de reden</items>
        </term_definitions>
        <term_definitions code="at0065">
          <items id="description">Genoteerde doelstelling van het verzoek door de verwijzer.</items>
          <items id="text">Doelstelling</items>
        </term_definitions>
        <term_definitions code="at0068">
          <items id="description">Urgentie van de aanvraag.</items>
          <items id="text">Urgentie</items>
        </term_definitions>
        <term_definitions code="at0076">
          <items id="description">Indien 'waar' geeft dit aan dat aanvullende informatie is geïdentificeerd en doorgestuurd wordt wanneer het beschikbaar is, bijvoorbeeld bij incomplete pathologie onderzoeksresultaten.</items>
          <items id="text">Aanvullende informatie die volgt</items>
        </term_definitions>
        <term_definitions code="at0078">
          <items id="description">Details van de aard van de aanvullende informatie dat nog volgt onder andere de naam van laboratorium uitslagen.</items>
          <items id="text">Aanvullende informatie verwacht</items>
        </term_definitions>
        <term_definitions code="at0112">
          <items id="description">Gedetailleerde lokale informatie zoals facturering vereisten.</items>
          <items id="text">Situering</items>
        </term_definitions>
        <term_definitions code="at0116">
          <items id="description">Taal, vervoer of andere persoonlijke voorwaarden om de aanwezigheid of deelname van de patient bij de uitvoering van de dienst te ondersteunen.</items>
          <items id="text">Patient voorwaarden</items>
        </term_definitions>
        <term_definitions code="at0121">
          <items id="description">Identificatie van de aangevraagde dienst. Dit is vaak gecodeerd op basis van externe terminologie.</items>
          <items id="text">Aanvraagde dienst</items>
        </term_definitions>
        <term_definitions code="at0127">
          <items id="description">De status van de aanvraag voor de dienst zoals aangegeven door de aanvrager. De status is gebruikt om aan te duiden of dit het initiële verzoek is, of een vervolg-verzoek om aanvullende informatie te leveren of aan te passen.</items>
          <items id="text">Status aanvraag</items>
        </term_definitions>
        <term_definitions code="at0128">
          <items id="description">Een lijst van personen of organisaties die een kopie van elke communicatie over de order dienen te ontvangen.</items>
          <items id="text">Distributielijst voor antwoord</items>
        </term_definitions>
        <term_definitions code="at0129">
          <items id="description">Datum laatste status wijziging.</items>
          <items id="text">Datum laatste status wijziging</items>
        </term_definitions>
        <term_definitions code="at0132">
          <items id="description">Gestructureerde details die de aangevraagde dienst omschrijven zoals CLUSTER archetype die beschrijft welke specifieke catheter ingebracht moet worden.</items>
          <items id="text">Specifieke details</items>
        </term_definitions>
        <term_definitions code="at0135">
          <items id="description">Een gedetailleerde beschrijving van de aangevraagde dienst.</items>
          <items id="text">Beschrijving van de dienst</items>
        </term_definitions>
        <term_definitions code="at0136">
          <items id="description">De aanvraag is spoed.</items>
          <items id="text">Spoed</items>
        </term_definitions>
        <term_definitions code="at0137">
          <items id="description">De aanvraag is dringend.</items>
          <items id="text">Dringend</items>
        </term_definitions>
        <term_definitions code="at0138">
          <items id="description">De aanvraag is routine.</items>
          <items id="text">Routine</items>
        </term_definitions>
        <term_definitions code="at0141">
          <items id="description">Details over de zorgverlener or zorg-organisatie die de dienst aanvragen.</items>
          <items id="text">Aanvrager</items>
        </term_definitions>
        <term_definitions code="at0142">
          <items id="description">Details over de zorgverlener of zorg-organisatie die de aanvraag voor de dienst ontvangt.</items>
          <items id="text">Ontvanger</items>
        </term_definitions>
        <term_definitions code="at0144">
          <items id="description">*The latest date that is acceptable for the service to be completed.(en)</items>
          <items id="text">*Latest date service required(en)</items>
        </term_definitions>
        <term_definitions code="at0144.1">
          <items id="description">De uiterste datum/tijd waarvoor het acceptabel is dat de dienst afgerond is.</items>
          <items id="text">Uiterste datum/tijd onderzoek</items>
        </term_definitions>
      </children>
      <cardinality>
        <is_ordered>false</is_ordered>
        <is_unique>false</is_unique>
        <interval>
          <lower_included>true</lower_included>
          <lower_unbounded>false</lower_unbounded>
          <upper_unbounded>true</upper_unbounded>
          <lower>0</lower>
        </interval>
      </cardinality>
    </attributes>
    <archetype_id>
      <value>openEHR-EHR-COMPOSITION.request.v1</value>
    </archetype_id>
    <template_id>
      <value>Laboratorium opdracht.v1</value>
    </template_id>
    <term_definitions code="at0000">
      <items id="description">Document verstuurd van de ene behandelende zorgaanbieder of organisatie naar een andere, met als doel het vragen van advies, een dienst of overdracht van zorg.</items>
      <items id="text">Verzoek voor een dienst</items>
    </term_definitions>
    <term_definitions code="at0001">
      <items id="description">@ internal @</items>
      <items id="text">Tree</items>
    </term_definitions>
    <term_definitions code="at0042">
      <items id="comment">Bijvoorbeeld: Informatie van lokale ziekenhuis afdelingen of aanvullende metagegevens verbinden met FHIR of CIMI equivalenten.</items>
      <items id="description">Aanvullende informatie vereist om de lokale context te vatten of om te verbinden met andere referentie modellen/formalismen.</items>
      <items id="text">Extensie</items>
    </term_definitions>
  </definition>
  <view />
</template>