                <archetype_id>
                  <value>openEHR-EHR-CLUSTER.pzp_conversation.v1</value>
                </archetype_id>
                <term_definitions code="at0001">
                  <items id="text">Type gesprek</items>
                  <items id="description">Aanduiding of het een eerste, vervolg- of herzieningsgesprek betreft.</items>
                </term_definitions>
                <term_definitions code="at1001">
                  <items id="text">Eerste gesprek</items>
                  <items id="description">Het eerste proactieve zorgplanningsgesprek met de patiënt.</items>
                </term_definitions>
                <term_definitions code="at1002">
                  <items id="text">Vervolg gesprek</items>
                  <items id="description">Een vervolg op een eerder gevoerd proactief zorgplanningsgesprek.</items>
                </term_definitions>
                <term_definitions code="at1003">
                  <items id="text">Herziening / actualisatie</items>
                  <items id="description">Een herziening of actualisatie van eerder vastgelegde proactieve zorgplanning.</items>
                </term_definitions>
                <term_definitions code="at0002">
                  <items id="text">Aanleiding gesprek</items>
                  <items id="description">De reden of aanleiding voor het voeren van dit PZP-gesprek.</items>
                </term_definitions>
                <term_definitions code="at0003">
                  <items id="text">Relatie met eerder PZP-gesprek</items>
                  <items id="description">Verwijzing naar een eerder PZP-gesprek waarop dit gesprek voortbouwt.</items>
                </term_definitions>
                <term_definitions code="at0004">
                  <items id="text">Processtatus</items>
                  <items id="description">De status van het PZP-proces ten tijde van vastlegging.</items>
                </term_definitions>
                <term_definitions code="at2001">
                  <items id="text">Gestart</items>
                  <items id="description">Het PZP-proces is gestart maar nog niet afgerond.</items>
                </term_definitions>
                <term_definitions code="at2002">
                  <items id="text">Vastgelegd</items>
                  <items id="description">De uitkomsten van het PZP-gesprek zijn vastgelegd.</items>
                </term_definitions>
                <term_definitions code="at2003">
                  <items id="text">Bevestigd</items>
                  <items id="description">De vastgelegde PZP-afspraken zijn bevestigd.</items>
                </term_definitions>
                <term_definitions code="at2004">
                  <items id="text">Herzien</items>
                  <items id="description">De PZP-afspraken zijn herzien ten opzichte van eerdere vastlegging.</items>
                </term_definitions>
                <term_definitions code="at0005">
                  <items id="text">Datum laatste bevestiging</items>
                  <items id="description">Datum waarop de PZP-afspraken voor het laatst zijn bevestigd.</items>
                </term_definitions>
                <term_definitions code="at0006">
                  <items id="text">Toelichting</items>
                  <items id="description">Aanvullende toelichting op het PZP-gesprek of het proces.</items>
                </term_definitions>
                <term_definitions code="at0000">
                  <items id="text">PZP gesprek</items>
                  <items id="description">Context- en procesinformatie over een proactief zorgplanningsgesprek.</items>
                </term_definitions>
              </children>
