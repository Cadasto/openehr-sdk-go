        <archetype_id>
          <value>openEHR-EHR-EVALUATION.advance_intervention_decisions.v1</value>
        </archetype_id>
        <term_definitions code="at0001">
          <items id="text">Structuur</items>
          <items id="description">@ intern @</items>
        </term_definitions>
        <term_definitions code="at0002">
          <items id="text">Intentie van zorg</items>
          <items id="description">De overkoepelende intentie voor toekomstige zorg en behandeling van de patiënt.</items>
          <items id="comment">Waar mogelijk verdient codering met een externe terminologie de voorkeur.</items>
        </term_definitions>
        <term_definitions code="at0003">
          <items id="text">Curatief</items>
          <items id="description">De aandoening is te genezen; alle passende levensverlengende behandelingen worden aangeboden.</items>
        </term_definitions>
        <term_definitions code="at0004">
          <items id="text">Herstellend</items>
          <items id="description">De aandoening is behandelbaar met kans op herstel of langdurige remissie; alle passende levensverlengende behandelingen worden aangeboden.</items>
        </term_definitions>
        <term_definitions code="at0005">
          <items id="text">Ondersteunend / palliatief</items>
          <items id="description">De aandoening is ongeneeslijk en progressief; behandeling is gericht op symptoomverlichting, comfort, kwaliteit van leven en waardigheid.</items>
        </term_definitions>
        <term_definitions code="at0006">
          <items id="text">Terminaal</items>
          <items id="description">De levensverwachting is zeer beperkt (uren of dagen); geen levensverlengende behandeling; focus op comfort en waardigheid.</items>
        </term_definitions>
        <term_definitions code="at0007">
          <items id="text">Onbekend</items>
          <items id="description">De intentie van zorg is niet bekend.</items>
        </term_definitions>
        <term_definitions code="at0008">
          <items id="text">Toelichting behandelgrenzen</items>
          <items id="description">Narratieve beschrijving van alle behandelgrenzen, inclusief eventuele reanimatieafspraken.</items>
          <items id="comment">Kan gebruikt worden voor vrije tekst, legacy data of aanvullende context naast gestructureerde vastlegging.</items>
        </term_definitions>
        <term_definitions code="at0009">
          <items id="text">Reanimatiebesluit</items>
          <items id="description">Besluit over de mate waarin cardiopulmonale reanimatie (CPR) passend is voor deze patiënt.</items>
        </term_definitions>
        <term_definitions code="at0010">
          <items id="text">Volledige reanimatie</items>
          <items id="description">Alle passende reanimatiehandelingen worden uitgevoerd om het leven te redden of te verlengen.</items>
        </term_definitions>
        <term_definitions code="at0011">
          <items id="text">Beperkte reanimatie</items>
          <items id="description">Reanimatie wordt uitgevoerd onder specifieke voorwaarden, zoals vastgelegd in de toelichting of per interventie.</items>
        </term_definitions>
        <term_definitions code="at0012">
          <items id="text">Niet reanimeren</items>
          <items id="description">Er worden geen reanimatiehandelingen uitgevoerd (DNR/DNAR/NFR).</items>
        </term_definitions>
        <term_definitions code="at0013">
          <items id="text">Onbekend</items>
          <items id="description">Het reanimatiebesluit is niet bekend.</items>
        </term_definitions>
        <term_definitions code="at0014">
          <items id="text">Per interventie</items>
          <items id="description">Besluiten per mogelijke medische interventie die levensreddend, levensverlengend of belastend kunnen zijn.</items>
        </term_definitions>
        <term_definitions code="at0015">
          <items id="text">Interventie</items>
          <items id="description">Naam van de mogelijke medische behandeling, handeling of procedure.</items>
          <items id="comment">Het voorgestelde waardenbereik is niet uitputtend; DV_TEXT kan worden gebruikt voor lokale uitbreidingen.</items>
        </term_definitions>
        <term_definitions code="at0016">
          <items id="text">Thoraxcompressies</items>
          <items id="description">Handmatige techniek om bloedcirculatie te ondersteunen tijdens een circulatiestilstand.</items>
        </term_definitions>
        <term_definitions code="at0017">
          <items id="text">Defibrillatie</items>
          <items id="description">Toediening van een elektrische schok om het hartritme te herstellen.</items>
        </term_definitions>
        <term_definitions code="at0018">
          <items id="text">Intubatie</items>
          <items id="description">Inbrengen van een tube in de trachea om de luchtweg open te houden, inclusief tracheostomie.</items>
        </term_definitions>
        <term_definitions code="at0019">
          <items id="text">Invasieve beademing</items>
          <items id="description">Kunstmatige ventilatie met gebruik van invasieve middelen.</items>
        </term_definitions>
        <term_definitions code="at0020">
          <items id="text">Niet-invasieve beademing</items>
          <items id="description">Kunstmatige ventilatie zonder invasieve middelen.</items>
        </term_definitions>
        <term_definitions code="at0021">
          <items id="text">Perifeer infuus</items>
          <items id="description">Inbrengen van een perifere intraveneuze lijn.</items>
        </term_definitions>
        <term_definitions code="at0022">
          <items id="text">Centraal veneuze of arteriële lijn</items>
          <items id="description">Inbrengen van een centraal veneuze lijn of arteriële lijn.</items>
        </term_definitions>
        <term_definitions code="at0023">
          <items id="text">Parenterale vochttoediening</items>
          <items id="description">Toediening van vocht via andere wegen dan eten of drinken.</items>
        </term_definitions>
        <term_definitions code="at0024">
          <items id="text">Parenterale of kunstmatige voeding</items>
          <items id="description">Toediening van voeding via andere wegen dan eten of drinken.</items>
        </term_definitions>
        <term_definitions code="at0025">
          <items id="text">Medicatie bij circulatiestilstand</items>
          <items id="description">Medicatie gebruikt tijdens reanimatie, zoals adrenaline of andere vasoactieve middelen.</items>
        </term_definitions>
        <term_definitions code="at0026">
          <items id="text">Circulatie-ondersteunende medicatie</items>
          <items id="description">Medicatie ter ondersteuning van de hartfunctie, zoals vasopressoren en inotrope middelen.</items>
        </term_definitions>
        <term_definitions code="at0027">
          <items id="text">Antibiotica / antivirale / antifungale middelen</items>
          <items id="description">Medicatie voor de behandeling van infecties.</items>
        </term_definitions>
        <term_definitions code="at0028">
          <items id="text">Bloedproducten</items>
          <items id="description">Therapeutische producten afkomstig van humaan bloed, zoals bloedcomponenten of plasmaderivaten.</items>
        </term_definitions>
        <term_definitions code="at0029">
          <items id="text">Thoraxdrainage</items>
          <items id="description">Inbrengen van een drain in de pleuraholte.</items>
        </term_definitions>
        <term_definitions code="at0030">
          <items id="text">Pacemaker</items>
          <items id="description">Inbrengen van een kunstmatige pacemaker om het hartritme te reguleren.</items>
        </term_definitions>
        <term_definitions code="at0031">
          <items id="text">Dialyse</items>
          <items id="description">Verwijderen van afvalstoffen en overtollig vocht uit het bloed.</items>
        </term_definitions>
        <term_definitions code="at0032">
          <items id="text">Overplaatsing naar ziekenhuis</items>
          <items id="description">Overplaatsing naar een ziekenhuis voor beoordeling of opname.</items>
        </term_definitions>
        <term_definitions code="at0033">
          <items id="text">Overplaatsing naar intensive care</items>
          <items id="description">Overplaatsing en opname op een intensive care- of high care-afdeling.</items>
        </term_definitions>
        <term_definitions code="at0034">
          <items id="text">Besluit</items>
          <items id="description">Het genomen besluit over de betreffende interventie.</items>
        </term_definitions>
        <term_definitions code="at0035">
          <items id="text">Aanbevolen</items>
          <items id="description">De interventie wordt aanbevolen.</items>
        </term_definitions>
        <term_definitions code="at0036">
          <items id="text">Voorwaardelijk aanbevolen</items>
          <items id="description">De interventie wordt alleen aanbevolen onder specifieke omstandigheden.</items>
        </term_definitions>
        <term_definitions code="at0037">
          <items id="text">Niet aanbevolen</items>
          <items id="description">De interventie wordt niet aanbevolen.</items>
        </term_definitions>
        <term_definitions code="at0038">
          <items id="text">Onbekend</items>
          <items id="description">Het besluit over deze interventie is niet bekend.</items>
        </term_definitions>
        <term_definitions code="at0039">
          <items id="text">Voorwaarde</items>
          <items id="description">Omschrijving van de omstandigheden waaronder een voorwaardelijk besluit geldt.</items>
        </term_definitions>
        <term_definitions code="at0040">
          <items id="text">Toelichting</items>
          <items id="description">Aanvullende toelichting of motivatie bij het besluit.</items>
        </term_definitions>
        <term_definitions code="at0041">
          <items id="text">Aanvullende details</items>
          <items id="description">Aanvullende gestructureerde informatie over de behandelgrenzen.</items>
        </term_definitions>
        <term_definitions code="at0042">
          <items id="text">Patiënt geïnformeerd</items>
          <items id="description">Beschrijving van de mate waarin de patiënt op de hoogte is van de behandelgrenzen.</items>
        </term_definitions>
        <term_definitions code="at0043">
          <items id="text">Naasten geïnformeerd</items>
          <items id="description">Beschrijving van de mate waarin naasten of vertegenwoordigers zijn geïnformeerd.</items>
        </term_definitions>
        <term_definitions code="at0044">
          <items id="text">Algemene toelichting</items>
          <items id="description">Overkoepelende toelichting die niet in andere elementen is vastgelegd.</items>
        </term_definitions>
        <term_definitions code="at0045">
          <items id="text">Structuur</items>
          <items id="description">@ intern @</items>
        </term_definitions>
        <term_definitions code="at0046">
          <items id="text">Laatst bijgewerkt</items>
          <items id="description">Datum en tijd waarop de behandelgrenzen voor het laatst zijn bijgewerkt.</items>
        </term_definitions>
        <term_definitions code="at0047">
          <items id="text">Geldig vanaf</items>
          <items id="description">Datum en tijd waarop de behandelgrenzen van kracht worden.</items>
        </term_definitions>
        <term_definitions code="at0048">
          <items id="text">Geldig tot</items>
          <items id="description">Datum en tijd waarop de behandelgrenzen niet langer geldig zijn.</items>
        </term_definitions>
        <term_definitions code="at0049">
          <items id="text">Herziening gepland</items>
          <items id="description">Datum waarop herziening van de behandelgrenzen gewenst is.</items>
        </term_definitions>
        <term_definitions code="at0050">
          <items id="text">Grondslag</items>
          <items id="description">Wettelijke of beleidsmatige grondslag, zoals een wilsverklaring of behandelafspraak.</items>
        </term_definitions>
        <term_definitions code="at0051">
          <items id="text">Digitale representatie</items>
          <items id="description">Digitaal document, afbeelding of video waarin de behandelgrenzen zijn vastgelegd.</items>
        </term_definitions>
        <term_definitions code="at0052">
          <items id="text">Documentlocatie</items>
          <items id="description">Informatie over de fysieke of digitale locatie van het document.</items>
        </term_definitions>
        <term_definitions code="at0053">
          <items id="text">Locatie</items>
          <items id="description">De fysieke of digitale locatie van het document.</items>
        </term_definitions>
        <term_definitions code="at0054">
          <items id="text">Kopiehouder</items>
          <items id="description">Persoon of organisatie die een kopie van het document bezit.</items>
        </term_definitions>
        <term_definitions code="at0055">
          <items id="text">Uitbreiding</items>
          <items id="description">Aanvullende lokale informatie of metadata.</items>
        </term_definitions>
        <term_definitions code="at0056">
          <items id="text">Onderbouwing</items>
          <items id="description">Toelichting op de onderbouwing van de gekozen intentie van zorg.</items>
        </term_definitions>
        <term_definitions code="at0000">
          <items id="text">Behandelgrenzen</items>
          <items id="description">Vooraf vastgelegde beslissingen over de algemene intentie van zorg en mogelijke medische interventies (waaronder behandelingen, handelingen en diagnostische of therapeutische procedures), meestal vastgesteld door een zorgverlener.</items>
        </term_definitions>
        <term_bindings terminology="SNOMED-CT">
          <items code="at0012">
            <value>
              <terminology_id>
                <value>SNOMED-CT</value>
              </terminology_id>
              <code_string>[SNOMED-CT::450476008]</code_string>
            </value>
          </items>
        </term_bindings>
      </children>
      <cardinality>
        <is_ordered>false</is_ordered>
        <is_unique>false</is_unique>
        <interval>
          <lower_included>true</lower_included>
          <upper_included>false</upper_included>
          <lower_unbounded>false</lower_unbounded>
          <upper_unbounded>true</upper_unbounded>
          <lower>1</lower>
        </interval>
      </cardinality>
    </attributes>
    <archetype_id>
      <value>openEHR-EHR-COMPOSITION.advance_care.v0</value>
    </archetype_id>
    <template_id>
      <value>Proactieve Zorgplanning</value>
    </template_id>
    <term_definitions code="at0001">
      <items id="text">Gecodeerde tekst</items>
      <items id="description"/>
    </term_definitions>
    <term_definitions code="at0002">
      <items id="text">Gebeurteniscontext</items>
      <items id="description">Contextinformatie over het moment en de omstandigheden waarin de proactieve zorgplanning is vastgelegd.</items>
    </term_definitions>
    <term_definitions code="at0003">
      <items id="text">Structuur</items>
      <items id="description">@ intern @</items>
    </term_definitions>
    <term_definitions code="at0004">
      <items id="text">Uitbreiding</items>
      <items id="description">Aanvullende informatie om het model uit te breiden met lokale inhoud of af te stemmen op andere referentiemodellen of informatiestandaarden.</items>
      <items id="comment">Bijvoorbeeld: lokale informatiebehoeften of aanvullende metadata voor afstemming met FHIR.</items>
    </term_definitions>
    <term_definitions code="at0000">
      <items id="text">Proactieve Zorgplanning</items>
      <items id="description">Een plan voor het omgaan met toekomstige gezondheids- en sociale zorgbehoeften, waaronder chronische zorg en zorg rond het levenseinde.</items>
    </term_definitions>
  </definition>
</OPERATIONAL_TEMPLATE>