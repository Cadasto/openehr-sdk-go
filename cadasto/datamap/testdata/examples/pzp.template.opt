                  <items id="text">Elektronische communicatie</items>
                  <items id="description">Digitale contactgegevens van de persoon.</items>
                </term_definitions>
                <term_definitions code="at0007">
                  <items id="text">Organisatie</items>
                  <items id="description">Organisatie waaraan de persoon verbonden is.</items>
                </term_definitions>
                <term_definitions code="at0008">
                  <items id="text">Aanvullende gegevens</items>
                  <items id="description">Overige relevante informatie over de persoon.</items>
