                <term_definitions code="at0011">
                  <items id="text">Label</items>
                  <items id="description">Een herkenbaar label voor de persoon.</items>
                </term_definitions>
                <term_definitions code="at0002">
                  <items id="text">Gestructureerde naam</items>
                  <items id="description">Gestructureerde weergave van de naam van een persoon.</items>
                </term_definitions>
                <term_definitions code="at0003">
                  <items id="text">Identificatie</items>
                  <items id="description">Identificerend gegeven van de persoon.</items>
                </term_definitions>
                <term_definitions code="at0004">
                  <items id="text">Rol</items>
                  <items id="description">Relatie of rol van de persoon ten opzichte van de patiënt of het dossier.</items>
                </term_definitions>
                <term_definitions code="at0005">
                  <items id="text">Adres</items>
                  <items id="description">Adresgegevens van de persoon.</items>
                </term_definitions>
