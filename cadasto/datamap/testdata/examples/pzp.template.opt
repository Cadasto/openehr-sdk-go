                <term_definitions code="at0001">
                  <items id="text">Wat is belangrijk voor de patiënt</items>
                  <items id="description">Samenvatting van wat voor de persoon het belangrijkst is in het leven en in de zorg.</items>
                </term_definitions>
                <term_definitions code="at0002">
                  <items id="text">Persoonlijke waarden</items>
                  <items id="description">Persoonlijke waarden die richting geven aan keuzes en voorkeuren.</items>
                </term_definitions>
                <term_definitions code="at0003">
                  <items id="text">Levensdoelen</items>
                  <items id="description">Levensdoelen of prioriteiten die de persoon wil behouden of bereiken.</items>
                </term_definitions>
                <term_definitions code="at0004">
                  <items id="text">Zingevingsaspecten</items>
                  <items id="description">Spirituele, levensbeschouwelijke of existentiële aspecten die belangrijk zijn voor de persoon.</items>
                </term_definitions>
                <term_definitions code="at0005">
                  <items id="text">Narratieve toelichting</items>
                  <items id="description">Aanvullende vrije toelichting op de waarden en doelen van de persoon.</items>
                </term_definitions>
                <term_definitions code="at0000">
                  <items id="text">Waarden en doelen</items>
                  <items id="description">Persoonlijke waarden, doelen en zingevingsaspecten die relevant zijn voor proactieve zorgplanning.</items>
                </term_definitions>
