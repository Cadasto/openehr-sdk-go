            <term_definitions code="at0000">
              <items id="text">residence_principle</items>
              <items id="description">Adres gebaseerd op de ISO22220 standaard.</items>
            </term_definitions>
            <term_definitions code="at0001">
              <items id="text">Gegevens</items>
              <items id="description">Bevat alle gegevenselementen van een adres.</items>
            </term_definitions>
            <term_definitions code="at0461">
              <items id="text">Zakelijk adres</items>
              <items id="description">Used to indicate an address that is the physical location of a business or office at which an entity can be contacted.</items>
            </term_definitions>
            <term_definitions code="at0462">
              <items id="text">Postadres</items>
              <items id="description">Used to indicate an address that is only for correspondence and/or billing purposes.</items>
            </term_definitions>
            <term_definitions code="at0463">
              <items id="text">Tijdelijk adres</items>
              <items id="description">Temporary accommodation address (such as for a person who usually resides overseas or where the provider of the address is in temporary accommodation due to renovation or treatment).</items>
            </term_definitions>
            <term_definitions code="at0464">
              <items id="text">Hoofdadres</items>
              <items id="description">Used to indicate where a person is living. Note that this code is not valid for organisations.</items>
            </term_definitions>
            <term_definitions code="at0465">
              <items id="text">Geen vast adres</items>
              <items id="description">Used where a person has no fixed address.</items>
            </term_definitions>
            <term_definitions code="at0466">
              <items id="text">Onbekend/niet vermeld/onvoldoende beschreven</items>
              <items id="description">Unknown/not stated/inadequately described may also be used where the person has no fixed address or does not wish to have their residential or correspondence address recorded.</items>
            </term_definitions>
            <term_definitions code="at2404">
              <items id="text">Gemeente</items>
              <items id="description">Gemeente van inschrijving.</items>
            </term_definitions>
            <term_definitions code="at2467">
              <items id="text">Verblijfadres</items>
              <items id="description">Woon-/Verblijfadres.</items>
            </term_definitions>
            <term_definitions code="at2468">
              <items id="text">Vakantie adres</items>
              <items id="description">Vakantie adres.</items>
            </term_definitions>
            <term_definitions code="at2499">
              <items id="text">Opmerkingen</items>
              <items id="description">Other details or remarks.</items>
            </term_definitions>
            <term_definitions code="at2502">
              <items id="text">time_validity</items>
              <items id="description">De periode waarvoor dit woonplaatsbeginsel geldig is</items>
            </term_definitions>
