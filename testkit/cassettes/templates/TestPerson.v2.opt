            <term_definitions code="at0001">
              <items id="text">Gegevens</items>
              <items id="description">Identifier number or code, issuer, assigner and type of identifier.</items>
            </term_definitions>
            <term_definitions code="at0002">
              <items id="text">Geographic scope</items>
              <items id="description">Indicates the geographic area within which the identifier is valid.</items>
            </term_definitions>
            <term_definitions code="at0003">
              <items id="text">Issuing City</items>
              <items id="description">Indicates the city where the identifier was issued.</items>
            </term_definitions>
            <term_definitions code="at0004">
              <items id="text">Issuing State</items>
              <items id="description">Indicates the state where the identifier was issued.</items>
            </term_definitions>
            <term_definitions code="at0005">
              <items id="text">Issuing Country</items>
              <items id="description">Indicates the country where the identifier was issued.</items>
            </term_definitions>
            <term_definitions code="at0006">
              <items id="text">Time validity</items>
              <items id="description">Period in which this identifier is valid.</items>
            </term_definitions>
            <term_definitions code="at0007">
              <items id="text">Controle datum</items>
              <items id="description">Last verification date.</items>
            </term_definitions>
            <term_definitions code="at0010">
              <items id="text">Local</items>
              <items id="description">Indicates that this identifier is used locally.</items>
            </term_definitions>
            <term_definitions code="at0011">
              <items id="text">Area/Regional/District</items>
              <items id="description">Indicates that this identifier is used within a specific area.</items>
            </term_definitions>
            <term_definitions code="at0012">
              <items id="text">State/Province/Territory</items>
              <items id="description">Indicates that this identifier is used within a political boundary such as a state or territory or province.</items>
            </term_definitions>
            <term_definitions code="at0013">
              <items id="text">National</items>
              <items id="description">Indicates that this identifier is used nationally.</items>
            </term_definitions>
