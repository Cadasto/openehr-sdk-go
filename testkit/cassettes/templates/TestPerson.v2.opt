            <term_definitions code="at0002">
              <items id="text">Polisnummer</items>
              <items id="description">Polisnummer.</items>
            </term_definitions>
            <term_definitions code="at0003">
              <items id="text">Type</items>
              <items id="description">Het type van de zorgverzekering, extern gedefiniëerd.</items>
            </term_definitions>
            <term_definitions code="at0004">
              <items id="text">Datum van import</items>
              <items id="description">De datum waarop de zorgverzekering als laatste is geïmporteerd.</items>
            </term_definitions>
            <term_definitions code="at0005">
              <items id="text">Pakket</items>
              <items id="description">De pakketcode en pakketlabel van de zorgverzekering. Wordt gebruikt met andere velden om uniekheid te bepalen.</items>
            </term_definitions>
            <term_definitions code="at0006">
              <items id="text">Geldigheid</items>
              <items id="description">De start en einddatum van de zorgverzekering.</items>
            </term_definitions>
            <term_definitions code="at0007">
              <items id="text">Zorgverzekeraar</items>
              <items id="description">Een referentie naar de zorgverzekeraar van de zorgverzekering.</items>
            </term_definitions>
          </children>
