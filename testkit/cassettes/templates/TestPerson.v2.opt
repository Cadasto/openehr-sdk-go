        <archetype_id>
          <value>openEHR-DEMOGRAPHIC-ITEM_TREE.person_details.v2</value>
        </archetype_id>
        <term_definitions code="at0000">
          <items id="text">Persoon data</items>
          <items id="description">Demographic data about a person such as birth data, death data, sex, marital status, ethnic group and biometric identifier</items>
        </term_definitions>
        <term_definitions code="at0001">
          <items id="text">Geboortegegevens</items>
          <items id="description">Birth demographic data</items>
        </term_definitions>
        <term_definitions code="at0002">
          <items id="text">Overlijdensgegevens</items>
          <items id="description">Death demographic data</items>
        </term_definitions>
        <term_definitions code="at0004">
          <items id="text">Biometrisch identificatiemiddel</items>
          <items id="description">A person's biometric identifier</items>
        </term_definitions>
        <term_definitions code="at0005">
          <items id="text">Overige persoon identificatie</items>
          <items id="description">Other person identifiers: ID cards, driver's lisence, etc</items>
        </term_definitions>
        <term_definitions code="at0006">
          <items id="text">Aanvullend land geboden geboortedatum</items>
          <items id="description">Additional birth data that are country specific</items>
        </term_definitions>
        <term_definitions code="at0010">
          <items id="text">Geboortedatum</items>
          <items id="description">The date of birth of a person</items>
        </term_definitions>
        <term_definitions code="at0011">
          <items id="text">Extra informatie verwacht voor geboortedatum</items>
          <items id="description">Flag that indicates when the current date of birth requires follow-up to obtain a more accurate date</items>
        </term_definitions>
        <term_definitions code="at0012">
          <items id="text">Geboorteland</items>
          <items id="description">The country where a person was born</items>
        </term_definitions>
        <term_definitions code="at0013">
          <items id="text">Geboorte Provincie/staat/gebied</items>
          <items id="description">The State/territory/province where the person was born</items>
        </term_definitions>
        <term_definitions code="at0014">
          <items id="text">Geboorteplaats</items>
          <items id="description">The city/town/locality where the person was born</items>
        </term_definitions>
        <term_definitions code="at0015">
          <items id="text">Meerling</items>
          <items id="description">An indicator of multiple birth, showing the total number of births resulting from a single pregnancy</items>
        </term_definitions>
        <term_definitions code="at0016">
          <items id="text">Meerling volgorde</items>
          <items id="description">The sequential order of this person in a multiple birth regardless of live or still birth</items>
        </term_definitions>
        <term_definitions code="at0017">
          <items id="text">Geslacht</items>
          <items id="description">Geslacht van deze persoon.</items>
        </term_definitions>
        <term_definitions code="at0018">
          <items id="text">Register</items>
          <items id="description">Registry office that issued the birth certificate</items>
        </term_definitions>
        <term_definitions code="at0021">
          <items id="text">Overlijdensdatum</items>
          <items id="description">Overlijdensdatum van deze persoon.</items>
        </term_definitions>
        <term_definitions code="at0022">
          <items id="text">Bron van kennisgeving</items>
          <items id="description">Indicates the source of information about a subject of care’s death. This field provides an indication of the certainty of the information</items>
        </term_definitions>
        <term_definitions code="at0023">
          <items id="text">Land</items>
          <items id="description">The country where a person  died</items>
        </term_definitions>
        <term_definitions code="at0024">
          <items id="text">provincie</items>
          <items id="description">The state/territory/province where a person died</items>
        </term_definitions>
        <term_definitions code="at0025">
          <items id="text">Woonplaats</items>
          <items id="description">The city/town/locality where a person died</items>
        </term_definitions>
        <term_definitions code="at0026">
          <items id="text">Overlijdens certificaat</items>
          <items id="description">The number of the death certificaat</items>
        </term_definitions>
        <term_definitions code="at0031">
          <items id="text">Geslacht</items>
          <items id="description">The gender of the subject</items>
        </term_definitions>
        <term_definitions code="at0032">
          <items id="text">Meisjes naam</items>
          <items id="description">Mother's original family name</items>
        </term_definitions>
        <term_definitions code="at0033">
          <items id="text">Burgerlijke staat</items>
          <items id="description">De burgerlijke staat van een mens in de zin en betekenis van het burgerlijk wetboek.</items>
        </term_definitions>
        <term_definitions code="at0034">
          <items id="text">Etnische achtergrond</items>
          <items id="description">The person's ethnic background</items>
        </term_definitions>
        <term_definitions code="at0035">
          <items id="text">Opmerkingen</items>
          <items id="description">Comments recorded for a person registration to distinguish between two or more persons with the same or similar demographic information</items>
        </term_definitions>
        <term_definitions code="at0041">
          <items id="text">Type of biometric</items>
          <items id="description">Identification of the type of biometric identifier described by this set of data</items>
        </term_definitions>
        <term_definitions code="at0042">
          <items id="text">Biometric data template</items>
          <items id="description">The format for a BIR that is fully-defined by a CBEFF patron</items>
        </term_definitions>
        <term_definitions code="at0043">
          <items id="text">Biometric enrolment quality</items>
          <items id="description">A numeric indicator of the quality of the biometric object</items>
        </term_definitions>
        <term_definitions code="at0044">
          <items id="text">Biometric creating authority</items>
          <items id="description">This indicates the organization that created the biometric</items>
        </term_definitions>
        <term_definitions code="at0045">
          <items id="text">Location of biometric identifier</items>
          <items id="description">Where the biometric could represent a number of alternative options, the specific location should be identified. If the biometric represents more than one, multiple locations should be indicated</items>
        </term_definitions>
        <term_definitions code="at0046">
          <items id="text">Biometric device identification</items>
          <items id="description">An identifier assigned to a biometric product that unambiguously identifies the biometric product within the biometric products that have been assigned an identifier by a biometric product owner</items>
        </term_definitions>
        <term_definitions code="at0047">
          <items id="text">Biometric version</items>
          <items id="description">Version of the process used to produce this biometric. This relates to the software used, rather than the device specification. Abstract value(s) defined by the patron format specification that identify a version of the patron format</items>
        </term_definitions>
        <term_definitions code="at0048">
          <items id="text">Biometric date of creation</items>
          <items id="description">The date upon which the biometric identifier was created</items>
        </term_definitions>
        <term_definitions code="at0220">
          <items id="text">Registratie</items>
          <items id="description">Indicate that the notification source is a registry</items>
        </term_definitions>
        <term_definitions code="at0221">
          <items id="text">Zorgverlener</items>
          <items id="description">Indicate that the notification source is a healthcare provider</items>
        </term_definitions>
        <term_definitions code="at0222">
          <items id="text">Familielid</items>
          <items id="description">Indicate that the notification source is a relative</items>
        </term_definitions>
        <term_definitions code="at0223">
          <items id="text">Anders</items>
          <items id="description">Indicate that the notification source is another source</items>
        </term_definitions>
        <term_definitions code="at0224">
          <items id="text">Onbekend</items>
          <items id="description">Indicate that the notification source is unknown</items>
        </term_definitions>
        <term_definitions code="at0310">
          <items id="text">Man</items>
          <items id="description">Het geslacht is man.</items>
        </term_definitions>
        <term_definitions code="at0311">
          <items id="text">Vrouw</items>
          <items id="description">Het geslacht is vrouw.</items>
        </term_definitions>
        <term_definitions code="at0312">
          <items id="text">Ongedifferentieerd</items>
          <items id="description">Het geslacht van een persoon kan niet uniek worden gedefinieerd als man of vrouw, zoals een hermafrodiet.</items>
        </term_definitions>
        <term_definitions code="at0313">
          <items id="text">Onbekend</items>
          <items id="description">Het geslacht is onbekend.</items>
        </term_definitions>
        <term_definitions code="at0410">
          <items id="text">Finger print—rolled</items>
          <items id="description">Finger print—rolled</items>
        </term_definitions>
        <term_definitions code="at0411">
