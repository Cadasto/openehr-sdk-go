            <archetype_id>
              <value>openEHR-DEMOGRAPHIC-ADDRESS.electronic_communication.v2</value>
            </archetype_id>
            <term_definitions code="at0000">
              <items id="text">Elektronisch adres</items>
              <items id="description">The address of an electronic communication medium.</items>
            </term_definitions>
            <term_definitions code="at0001">
              <items id="text">Gegevens</items>
              <items id="description">Electronic communication medium components.</items>
            </term_definitions>
            <term_definitions code="at0003">
              <items id="text">Gebruik</items>
              <items id="description">A code representing the manner of use that a person/organization applies to an electronic medium.</items>
            </term_definitions>
            <term_definitions code="at0004">
              <items id="text">Tijd voorkeuren</items>
              <items id="description">An indication of the time of day preference for use of this electronic contact address.</items>
            </term_definitions>
            <term_definitions code="at0007">
              <items id="text">Gegeven</items>
              <items id="description">A unique combination of characters used as input to electronic telecommunication equipment for the purpose of establishing contact.</items>
            </term_definitions>
            <term_definitions code="at0009">
              <items id="text">Internet adres</items>
              <items id="description">Internet address.</items>
            </term_definitions>
            <term_definitions code="at0012">
              <items id="text">Identificatie van alle elektronische communicatiemiddelen</items>
              <items id="description">Identification of telephone, fax, pager, e-mail, etc.</items>
            </term_definitions>
            <term_definitions code="at0020">
              <items id="text">Telefoon</items>
              <items id="description">The medium is a telephone (not a mobile phone).</items>
            </term_definitions>
            <term_definitions code="at0021">
              <items id="text">Mobiel</items>
              <items id="description">The medium is a mobile phone (not a landline).</items>
            </term_definitions>
            <term_definitions code="at0022">
              <items id="text">Fax</items>
              <items id="description">The medium is a faxsimile machine.</items>
            </term_definitions>
            <term_definitions code="at0023">
              <items id="text">Pieper</items>
              <items id="description">The medium is a pager.</items>
            </term_definitions>
            <term_definitions code="at0024">
              <items id="text">E-mail</items>
              <items id="description">The medium is e-mail.</items>
            </term_definitions>
            <term_definitions code="at0025">
              <items id="text">URL</items>
              <items id="description">The medium is an internet address.</items>
            </term_definitions>
            <term_definitions code="at0030">
              <items id="text">Persoonlijk</items>
              <items id="description">The medium is for personal use.</items>
            </term_definitions>
            <term_definitions code="at0031">
              <items id="text">Zakelijk</items>
              <items id="description">The medium is for business use.</items>
            </term_definitions>
            <term_definitions code="at0032">
              <items id="text">Persoonlijk/Zakelijk</items>
              <items id="description">The medium is for both business and personal use.</items>
            </term_definitions>
            <term_definitions code="at0033">
              <items id="text">Anders</items>
              <items id="description">The medium is for another use, e.g., a telephone for contact, a relative's phone.</items>
            </term_definitions>
            <term_definitions code="at0040">
              <items id="text">Tijdens kantoor uren</items>
              <items id="description">The medium is accessible during the business hours.</items>
            </term_definitions>
            <term_definitions code="at0041">
              <items id="text">Overdag</items>
              <items id="description">The medium should be used during day time hours.</items>
            </term_definitions>
            <term_definitions code="at0042">
              <items id="text">Tijdens weekend</items>
              <items id="description">The medium should be used at the weekend.</items>
            </term_definitions>
            <term_definitions code="at0043">
              <items id="text">Elk moment</items>
              <items id="description">The medium can be used at all times.</items>
            </term_definitions>
            <term_definitions code="at0044">
              <items id="text">Avond / 's Nachts</items>
              <items id="description">The medium should be used during the evening or at night.</items>
            </term_definitions>
            <term_definitions code="at2434">
              <items id="text">Tijdelijk</items>
              <items id="description">The medium is for temporary use, i.e. availability is uncertain, may be or may be not good for visit or mailing.</items>
            </term_definitions>
            <term_definitions code="at2499">
              <items id="text">Opmerkingen</items>
              <items id="description">Other details or remarks.</items>
            </term_definitions>
            <term_definitions code="at2498">
              <items id="text">Sms notificaties</items>
              <items id="description">This field indicates whether this mobile phone number is allowed to be sent notifications via sms texts</items>
            </term_definitions>
          </children>
