        <archetype_id>
          <value>openEHR-DEMOGRAPHIC-PARTY_IDENTITY.person_name.v2</value>
        </archetype_id>
        <term_definitions code="at0000">
          <items id="text">Naamgegevens</items>
          <items id="description">Naamgegevens</items>
        </term_definitions>
        <term_definitions code="at0001">
          <items id="text">Naam</items>
          <items id="description">Rootconcept van de naamgegevens. De naamgegevens van een persoon bevatten voornamen, roepnaam, achternaam en eventueel de achternaam van de partner.</items>
        </term_definitions>
        <term_definitions code="at0002">
          <items id="text">Voornaam</items>
          <items id="description">Officiële voornamen van de persoon.</items>
        </term_definitions>
        <term_definitions code="at0003">
          <items id="text">Achternaam</items>
          <items id="description">Officiële achternaam van de persoon.</items>
        </term_definitions>
        <term_definitions code="at0004">
          <items id="text">Titel</items>
          <items id="description">Een eervolle adresvorm die begint met een naam, die wordt gebruikt bij het aanspreken van een persoon op naam, per post, telefoon of afhankelijk van de culturele situatie in persoon.</items>
        </term_definitions>
        <term_definitions code="at0005">
          <items id="text">Achtervoegsel</items>
          <items id="description">Additional term used following a person name.</items>
        </term_definitions>
        <term_definitions code="at0007">
          <items id="text">Alternatieve naam voorstellingen</items>
          <items id="description">Details of alternative representations such as local codesets or language variations.</items>
        </term_definitions>
        <term_definitions code="at0008">
          <items id="text">Voorkeursnaam</items>
          <items id="description">Indicates that this is the name by which a person chooses to be identified.</items>
        </term_definitions>
        <term_definitions code="at0009">
          <items id="text">Kwesties van nauwkeurigheid en privacy</items>
          <items id="description">An indicator of specific conditions or rules that should be applied to the use of the person name.</items>
        </term_definitions>
        <term_definitions code="at0010">
          <items id="text">Volledige naam</items>
          <items id="description">De volledige naam van de persoon als aaneenschakeling van de naamgegevens.</items>
        </term_definitions>
        <term_definitions code="at0019">
          <items id="text">Gebruik interval</items>
          <items id="description">The period of time for which the name usage applies.</items>
        </term_definitions>
        <term_definitions code="at0020">
          <items id="text">Gebruik ID</items>
          <items id="description">De ID van het concept die de volgorde van achternamen aangeeft, waarmee de persoon aangesproken of aangeschreven wil worden.</items>
        </term_definitions>
        <term_definitions code="at0021">
          <items id="text">Vertegenwoordiging gebruik</items>
          <items id="description">Name of the representational form used.</items>
        </term_definitions>
        <term_definitions code="at0022">
          <items id="text">Alternatieve vertegenwoordiging</items>
          <items id="description">Alternative Representation of this subject of care name using alternative styles of representation such as characters or language character set variations for local display.</items>
        </term_definitions>
        <term_definitions code="at0023">
          <items id="text">Rapportage naam</items>
          <items id="description">The subject's name as it is to be used for reporting, when used with a specific identifier.</items>
        </term_definitions>
        <term_definitions code="at0024">
          <items id="text">Pasgeboren naam</items>
          <items id="description">A type reserved for the identification of unnamed newborn babies.</items>
        </term_definitions>
        <term_definitions code="at0025">
          <items id="text">Professionele of zakelijke naam</items>
          <items id="description">The name used by the subject for business or professional purposes.</items>
        </term_definitions>
        <term_definitions code="at0026">
          <items id="text">Meisjesnaam</items>
          <items id="description">The name used by the subject of care prior to marriage.</items>
        </term_definitions>
        <term_definitions code="at0027">
          <items id="text">Officiële naam</items>
          <items id="description">Registered name (Legal name).</items>
        </term_definitions>
        <term_definitions code="at0028">
          <items id="text">Andere naam</items>
          <items id="description">Any other name by which the subject is known, or has been known by in the past.</items>
        </term_definitions>
        <term_definitions code="at0031">
          <items id="text">Onbetrouwbare informatie</items>
          <items id="description">The name recorded is a fictitious or partial name.</items>
        </term_definitions>
        <term_definitions code="at0032">
          <items id="text">Bekend spelfout</items>
          <items id="description">This is a misspelling, but should be retained for potential future matching.</items>
        </term_definitions>
        <term_definitions code="at0033">
          <items id="text">Naam niet te gebruiken</items>
          <items id="description">This name should not be used when referring to this subject.</items>
        </term_definitions>
        <term_definitions code="at0034">
          <items id="text">Naam koppeling bij wet verboden</items>
          <items id="description">By Law, this name and all names prior to it in the name sequence are not to be displayed or indicated in any way when searching for or dealing with information and events associated with a name that is subsequent to this one in the name sequence.</items>
        </term_definitions>
        <term_definitions code="at0035">
          <items id="text">Speciale privacy / security eisen</items>
          <items id="description">A name for which episodes are attached that should only be accessible to specified authorised persons.</items>
        </term_definitions>
        <term_definitions code="at0036">
          <items id="text">Tijdelijke naam</items>
          <items id="description">A temporary name issued where the subject's name has not been determined.</items>
        </term_definitions>
        <term_definitions code="at2401">
          <items id="text">Initialen</items>
          <items id="description">Initialen van de persoon.</items>
        </term_definitions>
        <term_definitions code="at2402">
          <items id="text">Roepnaam</items>
          <items id="description">De naam waarmee de persoon gebruikelijk aangesproken wordt.</items>
        </term_definitions>
        <term_definitions code="at2403">
          <items id="text">Partnernaam voorvoegsel</items>
          <items id="description">Bij de achternaam van de partner behorende voorvoegsels.</items>
        </term_definitions>
        <term_definitions code="at2404">
          <items id="text">Partnernaam</items>
          <items id="description">Officiële achternaam van de partner.</items>
        </term_definitions>
        <term_definitions code="at2405">
          <items id="text">Voorvoegsel</items>
          <items id="description">Bij de eigen achternaam behorende voorvoegsels.</items>
        </term_definitions>
        <term_definitions code="at2410">
          <items id="text">Voorkeursvolgorde van de naamdelen</items>
          <items id="description">Dit geeft de volgorde van naamdelen aan waarmee de persoon aangesproken of aangeschreven wil worden.</items>
        </term_definitions>
      </children>
      <cardinality>
        <is_ordered>true</is_ordered>
        <is_unique>false</is_unique>
        <interval>
          <lower_included>true</lower_included>
          <lower_unbounded>false</lower_unbounded>
          <upper_unbounded>true</upper_unbounded>
          <lower>1</lower>
        </interval>
      </cardinality>
