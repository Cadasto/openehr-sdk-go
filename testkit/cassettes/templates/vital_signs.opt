        <term_definitions code="at0000">
          <items id="text">Blood Pressure</items>
          <items id="description">The measurement by any means (invasive or non-invasive) of systemic arterial blood pressure which is deemed to represent the actual systemic blood pressure</items>
        </term_definitions>
        <term_definitions code="at0001">
          <items id="text">history</items>
          <items id="description">history Structural node</items>
        </term_definitions>
        <term_definitions code="at0002">
          <items id="text">Baseline reading</items>
          <items id="description">Baseline event in event history</items>
        </term_definitions>
        <term_definitions code="at0003">
          <items id="text">blood pressure</items>
          <items id="description">@ internal @</items>
        </term_definitions>
        <term_definitions code="at0004">
          <items id="text">Systolic</items>
          <items id="description">Peak systemic arterial blood pressure over one cycle - measured in systolic or contraction phase of the heart cycle</items>
        </term_definitions>
        <term_definitions code="at0005">
          <items id="text">Diastolic</items>
          <items id="description">Minimum systemic arterial blood pressure over one cycle - measured in the diastolic or relaxation phase</items>
        </term_definitions>
        <term_definitions code="at0006">
          <items id="text">any event</items>
          <items id="description">other event in event history</items>
        </term_definitions>
        <term_definitions code="at0007">
          <items id="text">state structure</items>
          <items id="description">@ internal @</items>
        </term_definitions>
        <term_definitions code="at0008">
          <items id="text">Position</items>
          <items id="description">The position of the patient's body at the time of measuring blood pressure</items>
        </term_definitions>
        <term_definitions code="at0009">
          <items id="text">Exertion level</items>
          <items id="description">The level of exertion at the time of taking the measurement</items>
        </term_definitions>
        <term_definitions code="at0010">
          <items id="text">Exercise</items>
          <items id="description">The classification of the exercise level</items>
        </term_definitions>
        <term_definitions code="at0011">
          <items id="text">list structure</items>
          <items id="description">list structure</items>
        </term_definitions>
        <term_definitions code="at0013">
          <items id="text">Cuff size</items>
          <items id="description">The size of the cuff if a sphygmomanometer is used</items>
        </term_definitions>
        <term_definitions code="at0014">
          <items id="text">Site of Measurement</items>
          <items id="description">The location in the body where the blood pressure was measured</items>
        </term_definitions>
        <term_definitions code="at0015">
          <items id="text">Adult</items>
          <items id="description">A cuff that is standard for an adult - bladder approx 13cm x 30cm</items>
        </term_definitions>
        <term_definitions code="at0016">
          <items id="text">Large Adult</items>
          <items id="description">A cuff for adults with larger arms - bladder approx 16cm x 38cm</items>
        </term_definitions>
        <term_definitions code="at0017">
          <items id="text">Paediatric/Child</items>
          <items id="description">A cuff that is appropriate for a child or thin arm - bladder approx 8cm x 21 cm</items>
        </term_definitions>
        <term_definitions code="at0022">
          <items id="text">At rest</items>
          <items id="description">The person is at rest and not in the recovery phase from exersion</items>
        </term_definitions>
        <term_definitions code="at0023">
          <items id="text">Post-exercise</items>
          <items id="description">Measurement is taken immediately after exercise</items>
        </term_definitions>
        <term_definitions code="at0024">
          <items id="text">During exercise</items>
          <items id="description">The measurement is taken during exercise</items>
        </term_definitions>
        <term_definitions code="at0025">
          <items id="text">Right arm</items>
          <items id="description">The right arm of the person</items>
        </term_definitions>
        <term_definitions code="at0026">
          <items id="text">Left arm</items>
          <items id="description">The left arm of the person</items>
        </term_definitions>
        <term_definitions code="at0027">
          <items id="text">Right leg</items>
          <items id="description">The right leg of the patient</items>
        </term_definitions>
        <term_definitions code="at0028">
          <items id="text">Left leg</items>
          <items id="description">The left leg of the person</items>
        </term_definitions>
        <term_definitions code="at0029">
          <items id="text">5 minute reading</items>
          <items id="description">Blood pressure reading after 5 minutes rest</items>
        </term_definitions>
        <term_definitions code="at0030">
          <items id="text">10 minute reading</items>
          <items id="description">Blood pressure reading after 10 minutes rest</items>
        </term_definitions>
        <term_definitions code="at0031">
          <items id="text">Postural change</items>
          <items id="description">The difference between standing and sitting/lying blood pressure</items>
        </term_definitions>
        <term_definitions code="at0032">
          <items id="text">Intra-arterial</items>
          <items id="description">Blood pressure monitored via an intra-arterial line</items>
        </term_definitions>
        <term_definitions code="at0033">
          <items id="text">Comment</items>
          <items id="description">Comment on blood pressure reading</items>
        </term_definitions>
        <term_definitions code="at1000">
          <items id="text">Standing</items>
          <items id="description">Standing at the time of blood pressure measurement</items>
        </term_definitions>
        <term_definitions code="at1001">
          <items id="text">Sitting</items>
          <items id="description">Sitting on bed or chair at the time of blood pressure measurement</items>
        </term_definitions>
        <term_definitions code="at1002">
          <items id="text">Reclining</items>
          <items id="description">Person reclining at 45 degrees at the time of blood pressure measurement</items>
        </term_definitions>
        <term_definitions code="at1003">
          <items id="text">Lying</items>
          <items id="description">Patient lying flat at the time of blood pressure measurement</items>
        </term_definitions>
        <term_definitions code="at1004">
          <items id="text">Paradox</items>
          <items id="description">Variation in blood pressure with respiration</items>
        </term_definitions>
        <term_definitions code="at1005">
          <items id="text">Tilt</items>
          <items id="description">The tilt of the surface on which the person is lying</items>
        </term_definitions>
        <term_definitions code="at1006">
          <items id="text">Mean Arterial Pressure</items>
          <items id="description">(MAP) The average arterial pressure that occurs over the entire course of the heart contraction and relaxation cycle - calculated by (2XSBP + DBP) divided by 3.</items>
        </term_definitions>
        <term_definitions code="at1007">
          <items id="text">Pulse Pressure</items>
          <items id="description">The variation in pressure over one contraction cycle</items>
        </term_definitions>
        <term_definitions code="at1008">
          <items id="text">Adult Thigh</items>
          <items id="description">A cuff used for an adult thigh - bladder approx 20cm x 42 cm</items>
        </term_definitions>
        <term_definitions code="at1009">
          <items id="text">Neonatal</items>
          <items id="description">A cuff used for a new born - bladder approx 3cm x 6cm</items>
        </term_definitions>
        <term_definitions code="at1010">
          <items id="text">Korotkoff sounds</items>
          <items id="description">Record which Korotkoff sound is used for determining Diastolic pressure</items>
        </term_definitions>
