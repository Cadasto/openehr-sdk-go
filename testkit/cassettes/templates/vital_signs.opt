        <term_definitions code="at0000">
          <items id="text">Respirations</items>
          <items id="description">The rate and character of breathing</items>
        </term_definitions>
        <term_definitions code="at0001">
          <items id="text">history</items>
          <items id="description">@ internal @</items>
        </term_definitions>
        <term_definitions code="at0002">
          <items id="text">Any event</items>
          <items id="description">Generic event</items>
        </term_definitions>
        <term_definitions code="at0003">
          <items id="text">List</items>
          <items id="description">@ internal @</items>
        </term_definitions>
        <term_definitions code="at0004">
          <items id="text">Rate</items>
          <items id="description">The rate of respirations</items>
        </term_definitions>
        <term_definitions code="at0005">
          <items id="text">Rhythm</items>
          <items id="description">The character of the respiration</items>
        </term_definitions>
        <term_definitions code="at0006">
          <items id="text">regular</items>
          <items id="description">regular respirations</items>
        </term_definitions>
        <term_definitions code="at0007">
          <items id="text">irregular</items>
          <items id="description">irregular respirations</items>
        </term_definitions>
        <term_definitions code="at0008">
          <items id="text">Cheyne-Stokes</items>
          <items id="description">gradual waxing and waning of respiration followed by a central apnoea or hypopnoea</items>
        </term_definitions>
        <term_definitions code="at0009">
          <items id="text">Character</items>
          <items id="description">The character of the respirations</items>
        </term_definitions>
        <term_definitions code="at0010">
          <items id="text">Gasping</items>
          <items id="description">Wide open mouth and desperate</items>
        </term_definitions>
        <term_definitions code="at0011">
          <items id="text">Grunting</items>
          <items id="description">Making a grunting noise at the end of expiration</items>
        </term_definitions>
        <term_definitions code="at0012">
          <items id="text">Kussmaul</items>
          <items id="description">Deep chest breathing with or without gasp seen (for instance) in hyperglycaemia</items>
        </term_definitions>
        <term_definitions code="at0013">
          <items id="text">Apnoeic episodes</items>
          <items id="description">Periods of apnoea</items>
        </term_definitions>
        <term_definitions code="at0014">
          <items id="text">Snoring</items>
          <items id="description">Making inspiratory and expiratory noises due the palate and softtissues collapsing</items>
        </term_definitions>
        <term_definitions code="at0015">
          <items id="text">Inspiratory stridor</items>
          <items id="description">Involuntary laryngeal noise on inspiration</items>
        </term_definitions>
        <term_definitions code="at0016">
