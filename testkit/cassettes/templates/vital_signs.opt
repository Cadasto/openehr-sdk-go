        </term_definitions>
        <term_definitions code="at0003">
          <items id="text">Any event</items>
          <items id="description">*</items>
        </term_definitions>
        <term_definitions code="at0004">
          <items id="text">Rate</items>
          <items id="description">The rate of the heart as beats per minute</items>
        </term_definitions>
        <term_definitions code="at0005">
          <items id="text">Rhythm</items>
          <items id="description">The rhythm of the heart beat</items>
        </term_definitions>
        <term_definitions code="at0006">
          <items id="text">Regular</items>
          <items id="description">Regular heart beat</items>
        </term_definitions>
        <term_definitions code="at0007">
          <items id="text">Irregular</items>
          <items id="description">The heart is irregular</items>
        </term_definitions>
        <term_definitions code="at0008">
          <items id="text">Irregularly irregular</items>
          <items id="description">Irregular in a chaotic manner</items>
        </term_definitions>
        <term_definitions code="at0009">
          <items id="text">Description</items>
          <items id="description">The description of the rate and rythm</items>
        </term_definitions>
        <term_definitions code="at0010">
          <items id="text">List</items>
          <items id="description">@ internal @</items>
        </term_definitions>
        <term_definitions code="at0011">
          <items id="text">Device</items>
          <items id="description">Device by which the heart rate was measured</items>
        </term_definitions>
        <term_definitions code="at0012">
          <items id="text">List</items>
          <items id="description">@ internal @</items>
        </term_definitions>
        <term_definitions code="at0013">
          <items id="text">Position</items>
          <items id="description">The position of the patient when the heart rate was measured</items>
        </term_definitions>
        <term_definitions code="at1000">
          <items id="text">Lying</items>
          <items id="description">Lying prone</items>
        </term_definitions>
        <term_definitions code="at1001">
          <items id="text">Sitting</items>
          <items id="description">Sitting on bed or chair</items>
        </term_definitions>
        <term_definitions code="at1002">
          <items id="text">Reclining</items>
          <items id="description">Person reclining at 45 degrees with legs raised</items>
        </term_definitions>
        <term_definitions code="at1003">
          <items id="text">Standing</items>
          <items id="description">Standing upright</items>
        </term_definitions>
        <term_definitions code="at1004">
          <items id="text">Normal statements </items>
          <items id="description">The heart rate is normal</items>
        </term_definitions>
        <term_definitions code="at1005">
          <items id="text">Present</items>
          <items id="description">The pulse rate is present (implied true if rate &gt; 0)</items>
        </term_definitions>
        <term_definitions code="at1007">
          <items id="text">Normal statements</items>
          <items id="description">Normal statements about the heart rate</items>
        </term_definitions>
        <term_definitions code="at1008">
          <items id="text">Normal sinus rhythm</items>
          <items id="description">The heart is beating in a normal manner</items>
        </term_definitions>
        <term_definitions code="at1009">
          <items id="text">Normal rate and rhythm</items>
          <items id="description">The heart is beating normally</items>
        </term_definitions>
        <term_definitions code="at1010">
          <items id="text">Normal</items>
          <items id="description">The heart rate is normal</items>
        </term_definitions>
