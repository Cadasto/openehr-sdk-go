          <items id="text">*Tree(nl)</items>
        </term_definitions>
        <term_definitions code="at0004">
          <items id="description">*</items>
          <items id="text">Taalvaardigheid</items>
        </term_definitions>
        <term_definitions code="at0005">
          <items id="description">De taal waarin de communicatie plaatsvindt.</items>
          <items id="text">Communicatietaal</items>
        </term_definitions>
        <term_definitions code="at0006">
          <items id="description">Het vermogen om in de betreffende taal uitgesproken tekst te verstaan en begrijpen. Het gaat hierbij om het taaltechnische aspect.</items>
          <items id="text">Taalvaardigheid begrijpen</items>
        </term_definitions>
        <term_definitions code="at0007">
          <items id="description">Het vermogen om zich in de betreffende taal mondeling uit te kunnen drukken.</items>
          <items id="text">Taalvaardigheid spreken</items>
        </term_definitions>
        <term_definitions code="at0008">
          <items id="description">Het vermogen om in de betreffende taal geschreven tekst te kunnen lezen en begrijpen. Het gaat hierbij om het taaltechnische aspect.</items>
          <items id="text">Taalvaardigheid lezen</items>
        </term_definitions>
        <term_definitions code="at0009">
          <items id="description">Een toelichting op de taalvaardigheid.</items>
          <items id="text">Toelichting</items>
        </term_definitions>
        <term_definitions code="at0010">
          <items id="description">Aanvullende manieren waarop de persoon kan communiceren, zoals braille, gebarentaal, etc.</items>
          <items id="text">Speciale behoeften</items>
        </term_definitions>
