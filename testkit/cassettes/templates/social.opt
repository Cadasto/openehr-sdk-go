        <term_definitions code="at0000">
          <items id="description">Summary or persistent information about an individual's current and past education or training.</items>
          <items id="text">Opleidingsniveau</items>
        </term_definitions>
        <term_definitions code="at0001">
          <items id="description">*@ internal @(nl)</items>
          <items id="text">*Tree(nl)</items>
        </term_definitions>
        <term_definitions code="at0002">
          <items id="comment">*Coding with a terminology is desirable, where possible. For example: the ISCED classification, such as upper secondary vocational education; post-secondary non-tertiary vocational education; Bachelor’s or equivalent level, professional; Doctoral or equivalent level, academic; post-secondary non-tertiary vocational education; or never attended an educational program.(en)</items>
          <items id="description">Hoogste behaalde niveau in opleiding</items>
          <items id="text">Hoogst behaalde niveau</items>
        </term_definitions>
        <term_definitions code="at0003">
          <items id="comment">*In the context of this archetype, formal education includes all education that is based on a structured curriculum and delivered by trained professionals.(en)</items>
          <items id="description">Leeftijd wanneer het individu voor het eerst is begonnen aan een opleiding.</items>
          <items id="text">Startleeftijd</items>
        </term_definitions>
        <term_definitions code="at0007">
          <items id="description">Toevoeging op de opleiding, wat niet beschreven is in andere velden.</items>
          <items id="text">Opmerking</items>
        </term_definitions>
        <term_definitions code="at0018">
          <items id="description">Omschrijving over de opleiding van het individu.</items>
          <items id="text">Omschrijving</items>
        </term_definitions>
        <term_definitions code="at0029">
          <items id="description">Gestructureerde details over elke opleiding of training, zowel huidig als verleden.</items>
          <items id="text">Opleidingsrecord</items>
        </term_definitions>
        <term_definitions code="at0030">
          <items id="comment">*For example: 'Special education needs'.(en)</items>
          <items id="description">Aanvullende details over de opleiding of training, of voorgaande opleidingshistorie van een individu.</items>
          <items id="text">Optionele details</items>
        </term_definitions>
        <term_definitions code="at0031">
          <items id="comment">*Usually only recorded when an individual has not achieved a recognized level of formal education, such as an individual who left school at the age of 13.(en)</items>
          <items id="description">Leeftijd wanneer het individu is geëindigd met zijn/haar opleidingen.</items>
          <items id="text">Eindleeftijd</items>
        </term_definitions>
