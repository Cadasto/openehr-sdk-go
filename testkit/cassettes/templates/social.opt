        <term_definitions code="at0004">
          <items id="description">De aard van de hulp/ondersteuning die geboden wordt aan de patiënt.</items>
          <items id="text">Aard</items>
        </term_definitions>
        <term_definitions code="at0005">
          <items id="description">De frequentie van de geboden ondersteuning, bijvoorbeeld dagelijks/wekelijks.</items>
          <items id="text">Frequentie</items>
        </term_definitions>
        <term_definitions code="at0006">
          <items id="description">Het type hulp dat de betrokken persoon biedt.</items>
          <items id="text">Soort hulp</items>
        </term_definitions>
        <term_definitions code="at0008">
          <items id="description">Een toelichting op de hulp/ondersteuning die de patiënt ontvangt van anderen.</items>
          <items id="text">Toelichting</items>
        </term_definitions>
        <term_definitions code="at0009">
          <items id="description">Een hulpverlener kan zijn een professionele zorgverlener zoals verpleegkundigen, zorgenden en helpenden maar ook een mantelzorger of een zorgaanbieder zoals een thuiszorgorganisatie.</items>
          <items id="text">Hulpverlener</items>
        </term_definitions>
