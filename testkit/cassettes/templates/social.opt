    <term_definitions code="at0002">
      <items id="comment">Bijvoorbeeld lokale ziekenhuisafdeling informatie of aanvullende metadata om uit in lijn te brengen met FHIR of CIMI-equivalenten.</items>
      <items id="description">Aanvullende informatie die vereist is om de lokale context vast te leggen of in lijn te brengen met andere referentie-modellen/formalismen.</items>
      <items id="text">Extensies</items>
    </term_definitions>
